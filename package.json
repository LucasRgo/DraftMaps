{
    "name": "draftmaps",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "scripts": {
        "start": "expo start",
        "reset-project": "node ./scripts/reset-project.js",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "build:web": "expo export --platform web",
        "dev:worker": "wrangler dev",
        "dev:expo": "node scripts/dev-expo.js",
        "cf:dev": "npx concurrently -k -n \"WORKER,EXPO\" -c \"blue,green\" \"npm run dev:worker\" \"npm run dev:expo\"",
        "cf:remote": "npm run build:web && wrangler dev --remote",
        "cf:deploy": "npm run build:web && wrangler deploy",
        "lint": "expo lint",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "npx tsx --test tests/api.test.ts tests/maps.test.ts tests/services.test.ts tests/worker.test.ts",
        "test:e2e": "npx serve dist -l 3000 --single & SERVER_PID=$!; npx playwright test tests/e2e.spec.ts; TEST_EXIT=$?; kill $SERVER_PID 2>/dev/null; exit $TEST_EXIT",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@react-navigation/native": "^7.1.8",
        "expo": "~54.0.34",
        "expo-constants": "~18.0.13",
        "expo-font": "~14.0.11",
        "expo-linking": "~8.0.12",
        "expo-router": "~6.0.23",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-system-ui": "~6.0.9",
        "leaflet": "^1.9.4",
        "nativewind": "^4.2.5",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-leaflet": "^5.0.0",
        "react-native": "0.81.5",
        "react-native-maps": "1.20.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-web": "~0.21.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/leaflet": "^1.9.21",
        "@types/react": "~19.1.0",
        "@types/react-test-renderer": "^19.1.0",
        "babel-preset-expo": "^54.0.11",
        "concurrently": "^10.0.3",
        "eslint": "^9.25.0",
        "eslint-config-expo": "~10.0.0",
        "react-test-renderer": "^19.1.0",
        "serve": "^14.2.6",
        "tailwindcss": "^3.4.19",
        "tsx": "^4.22.4",
        "typescript": "~5.9.2",
        "wrangler": "^4.99.0"
    },
    "private": true
}
