{
    "name": "draftmaps",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "scripts": {
        "start": "expo start",
        "reset-project": "node ./scripts/reset-project.js",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "build:web": "expo export --platform web",
        "cf:dev": "npm run build:web && wrangler dev",
        "cf:remote": "npm run build:web && wrangler dev --remote",
        "cf:deploy": "npm run build:web && wrangler deploy",
        "lint": "expo lint",
        "test": "npx tsx --test tests/api.test.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@react-navigation/native": "^7.1.8",
        "expo": "~54.0.34",
        "expo-constants": "~18.0.13",
        "expo-font": "~14.0.11",
        "expo-linking": "~8.0.12",
        "expo-router": "~6.0.23",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-system-ui": "~6.0.9",
        "leaflet": "^1.9.4",
        "nativewind": "^4.2.5",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-leaflet": "^5.0.0",
        "react-native": "0.81.5",
        "react-native-maps": "1.20.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-web": "~0.21.0"
    },
    "devDependencies": {
        "@types/leaflet": "^1.9.21",
        "@types/react": "~19.1.0",
        "babel-preset-expo": "^54.0.11",
        "eslint": "^9.25.0",
        "eslint-config-expo": "~10.0.0",
        "tsx": "^4.22.4",
        "typescript": "~5.9.2",
        "wrangler": "^4.99.0"
    },
    "private": true
}
